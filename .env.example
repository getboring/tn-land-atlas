# All Supabase access goes through Cloudflare Pages Functions, not the browser.
# Set these in the Cloudflare Pages project (Production + Preview):
#
#   SUPABASE_URL=https://xxx.supabase.co
#   SUPABASE_ANON_KEY=xxx
#
# `npm run dev` (Vite alone) does not need them — the property panel will just
# return empty enriched data. To exercise /api/property locally, run:
#
#   npx wrangler pages dev dist --port 5180 \
#     --binding SUPABASE_URL=... --binding SUPABASE_ANON_KEY=...
